# Routism self-hosted configuration
# Copy to .env and edit as needed. Never commit real secrets.

# --- Network ---
ROUTISM_PORT=8000
ROUTISM_UI_PORT=3000
ROUTISM_HOST=0.0.0.0
# Browser-facing API URL (for the dashboard container)
NEXT_PUBLIC_ROUTISM_API=http://localhost:8000
ROUTISM_PUBLIC_BASE_URL=http://localhost:8000/v1

# --- Data ---
# ROUTISM_DATA_DIR=/data

# --- API keys ---
# Optional fixed bootstrap key (must start with rtm_). If unset, first boot mints one
# into $ROUTISM_DATA_DIR/bootstrap_key.txt
# ROUTISM_API_KEY=rtm_your_long_secret_here

# Require Bearer key on all protected routes (set 1 if exposed to the internet)
ROUTISM_REQUIRE_API_KEY=0
# Allow key create/list without prior key on loopback (default 1)
ROUTISM_OPEN_LOCAL=1
# Allow unauthenticated chat/completions from loopback (default 1)
ROUTISM_ALLOW_ANON_LOOPBACK=1

# --- Pool secrets encryption ---
# Optional. If unset, a key is auto-created under data/local_fernet.key
# ROUTISM_FERNET_KEY=
# ROUTISM_SECRETS_KEY=

# --- Management mutations ---
# Optional. Unset = local dashboard allowed (loopback + Docker Desktop private
# source IPs when ROUTISM_OPEN_LOCAL=1). Set a strong secret only for remote admin.
# MANAGEMENT_API_KEY=

# Set automatically by docker-compose (do not set for native `python -m routism.run`)
# ROUTISM_IN_DOCKER=1

# --- Engine (Ollama on host) ---
# Conductor orchestration models live on the host Ollama daemon, not inside the API image.
# Docker Desktop (macOS/Windows) and Linux with compose extra_hosts host-gateway:
OLLAMA_BASE_URL=http://host.docker.internal:11434
# Local worker URLs like http://localhost:11434 are rewritten to host.docker.internal
# when ROUTISM_IN_DOCKER=1 so Providers "Connect Ollama" works without manual edits.
